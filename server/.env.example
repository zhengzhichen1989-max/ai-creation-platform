# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=./data/ai-creation.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Upload
UPLOAD_DIR=./uploads

# 邮件SMTP配置（密码找回功能）
# QQ邮箱: host=smtp.qq.com port=465 secure=true pass=授权码(非登录密码)
# 163邮箱: host=smtp.163.com port=465 secure=true
# Gmail: host=smtp.gmail.com port=587 secure=false
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@qq.com
EMAIL_PASS=your-smtp-auth-code
EMAIL_FROM_NAME=织影智作

# 微信支付V3配置
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY=
WECHAT_NOTIFY_URL=https://zhiyingworks.cn/api/v1/payment/notify
